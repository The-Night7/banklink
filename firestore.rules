rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read, write: if ownsUser(userId);

      match /{document=**} {
        allow read, write: if ownsUser(userId);
      }
    }
  }
}
