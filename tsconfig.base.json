{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@budgetlink/config": ["packages/config/src/index.ts"],
      "@budgetlink/domain": ["packages/domain/src/index.ts"],
      "@budgetlink/ui": ["packages/ui/src/index.ts"],
      "@budgetlink/ui/*": ["packages/ui/src/*"]
    }
  }
}
